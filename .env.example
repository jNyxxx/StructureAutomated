# AutomatedStructure — example environment configuration.
#
# Copy to `.env` (git-ignored) for local development and fill with values from
# your approved secrets backend. NEVER commit real secrets. Every value below is
# an intentionally non-functional placeholder.
#
# Production/staging secrets must come from the approved secrets backend
# (e.g. AWS Secrets Manager), not from a committed file — see CLAUDE.md §10 and
# the production boot guard.

# Environment: local | development | staging | demo | production
APP_ENV=local

# --- Database ---
# DATABASE_URL is for running the app directly on the host. Inside Docker
# Compose the backend/worker compose their own DSN from POSTGRES_* with host
# `db` (see docker-compose.yml), so this value is not used in-container.
DATABASE_URL=postgresql+asyncpg://app_user:CHANGE_ME@localhost:5432/automatedstructure

# --- Application security (generate strong random values; store in secrets backend) ---
JWT_SECRET=CHANGE_ME_PLACEHOLDER
ENCRYPTION_KEY=CHANGE_ME_PLACEHOLDER

# --- Provider mock/live flags (mocks allowed only for local/dev/demo per CLAUDE env guard) ---
MOCK_STRIPE=true
MOCK_MAILBOX=true
MOCK_DNS=true
MOCK_VERIFIER=true
MOCK_RESEARCH=true

# --- Stripe (placeholders only; real keys come from the secrets backend) ---
STRIPE_API_KEY=CHANGE_ME_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=CHANGE_ME_PLACEHOLDER
STRIPE_MODE=test
STRIPE_SECRET_KEY_REF=CHANGE_ME_PLACEHOLDER
STRIPE_WEBHOOKS_ENABLED=false
STRIPE_WEBHOOK_SECRET_REF=CHANGE_ME_PLACEHOLDER
STRIPE_CHECKOUT_ENABLED=false
STRIPE_BILLING_PORTAL_ENABLED=false
STRIPE_SUCCESS_URL=CHANGE_ME_PLACEHOLDER
STRIPE_CANCEL_URL=CHANGE_ME_PLACEHOLDER
STRIPE_PORTAL_RETURN_URL=CHANGE_ME_PLACEHOLDER
STRIPE_PRICE_IDS_REF=CHANGE_ME_PLACEHOLDER

# --- Email provider boundary (P3-5b: mock adapter only, no live provider enabled) ---
EMAIL_PROVIDER=mock
LIVE_EMAIL_SENDING_ENABLED=false
EMAIL_PROVIDER_SECRET_REF=CHANGE_ME_PLACEHOLDER
EMAIL_PROVIDER_WEBHOOK_SECRET_REF=CHANGE_ME_PLACEHOLDER
EMAIL_PROVIDER_WEBHOOKS_ENABLED=false
EMAIL_SENDING_DOMAIN=CHANGE_ME_PLACEHOLDER
EMAIL_TENANT_HOURLY_CAP=10
EMAIL_TENANT_DAILY_CAP=50
EMAIL_CAMPAIGN_DAILY_CAP=50
EMAIL_MAILBOX_DAILY_CAP=25

# --- Managed auth provider (Clerk; vendor recorded in ADR_AUTH_PROVIDER) ---
# Local/dev uses the mock verifier (MOCK_VERIFIER=true above) and ignores the
# values below. In production MOCK_VERIFIER must be false and these become
# required: issuer must be an https non-localhost URL, secret/publishable keys
# must come from the secrets backend (never committed). The production boot
# guard fails closed if any are blank/placeholder. controlled_demo does NOT
# bypass these auth requirements.
AUTH_PROVIDER=managed
# Clerk issuer, e.g. https://your-app.clerk.accounts.dev (no localhost/preview/wildcard in prod)
AUTH_PROVIDER_ISSUER=CHANGE_ME_PLACEHOLDER
# Optional: overrides {issuer}/.well-known/jwks.json
AUTH_PROVIDER_JWKS_URL=
# Optional: expected `aud` claim if a Clerk JWT template sets it
AUTH_PROVIDER_AUDIENCE=
# Optional: comma-separated allowed `azp` (authorized parties)
AUTH_PROVIDER_AUTHORIZED_PARTIES=
# Optional claim-name overrides (defaults: email / sid / unset)
AUTH_PROVIDER_EMAIL_CLAIM=email
AUTH_PROVIDER_SESSION_CLAIM=sid
AUTH_PROVIDER_MFA_CLAIM=
AUTH_PROVIDER_PUBLISHABLE_KEY=CHANGE_ME_PLACEHOLDER
AUTH_PROVIDER_SECRET_KEY=CHANGE_ME_PLACEHOLDER

# Roles requiring verified MFA (owner decision: platform_admin mandatory at launch).
# Comma-separated. Inert until the role exists in the RBAC matrix (services/authz.py).
AUTH_MFA_REQUIRED_ROLES=platform_admin

# --- Docker Compose local stack (see docker-compose.yml) ---
POSTGRES_USER=app_user
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=automatedstructure
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# n8n local basic auth (local dev only — not a real secret)
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_PORT=5678

# Optional tiers
LOCALSTACK_PORT=4566
REDIS_PORT=6379

# --- Rate limiting ---
# Local/test default stays in-memory. Production must use Redis for multi-worker correctness.
RATE_LIMIT_BACKEND=in_memory
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
